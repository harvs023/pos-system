# --- MySQL Database ---
# Example: mysql://user:password@localhost:3306/pos_db
DATABASE_URL="mysql://root:password@localhost:3306/pos_db"

# --- Auth ---
JWT_SECRET="change-this-to-a-long-random-string"

# --- Online Payments (PayMongo - supports GCash + Cards in the Philippines) ---
# Leave this OFF while you're testing the POS. Cash payments work regardless.
# Flip to "true" only once you have real/test PayMongo API keys below.
NEXT_PUBLIC_ENABLE_ONLINE_PAYMENTS="false"

# Get these from https://dashboard.paymongo.com/developers (use the TEST keys first)
PAYMONGO_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"
PAYMONGO_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"

# Used to build the redirect URLs PayMongo sends the customer back to
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
